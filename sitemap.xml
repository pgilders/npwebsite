---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign sitemap_pages = site.pages | where_exp: "item", "item.url == '/' or item.title" %}
  {% for sitemap_page in sitemap_pages %}
    {% unless sitemap_page.url == "/404.html" or sitemap_page.sitemap == false %}
      {% assign sitemap_url = sitemap_page.url | replace: "index.html","" | replace: ".html","" | absolute_url %}
  <url>
    <loc>{{ sitemap_url }}</loc>
  </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
    {% assign post_url = post.url | replace: "index.html","" | replace: ".html","" | absolute_url %}
  <url>
    <loc>{{ post_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
</urlset>
